# LLM Provider: "ollama" or "bedrock"
LLM_PROVIDER=ollama

# Ollama Configuration
# URL of your Ollama server (use host.docker.internal for local Ollama when running in Docker)
OLLAMA_BASE_URL=http://localhost:11434
# Model name (e.g., llama3, mistral, openai-oss-20b)
OLLAMA_MODEL=llama3

# AWS Bedrock Configuration (required only if using Bedrock)
# Generate an API key from the AWS Bedrock console
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
