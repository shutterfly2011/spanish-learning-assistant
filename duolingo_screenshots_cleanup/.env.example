# ── Input ──────────────────────────────────────────────────────────────────
# Folder containing the iPhone images to process.
# Can be overridden at runtime with:  python main.py --folder /path/to/photos
INPUT_FOLDER=/path/to/your/iphone/photos

# ── Ollama ─────────────────────────────────────────────────────────────────
# URL of your local-network Ollama server
OLLAMA_BASE_URL=http://192.168.1.100:11434

# Vision model for reading screenshots (must support image input)
# e.g. llava:latest, llama3.2-vision:latest, bakllava:latest
OLLAMA_VISION_MODEL=llava:latest

# Text model for applying rules (any capable chat model)
OLLAMA_MODEL=llama3

# ── MCP server ─────────────────────────────────────────────────────────────
# URL of the running buenospanish_mcp Docker container
MCP_SERVER_URL=http://localhost:8000

# ── Output ─────────────────────────────────────────────────────────────────
# Path to the markdown file where flashcards are appended
OUTPUT_MARKDOWN_FILE=/path/to/your/flashcards.md
