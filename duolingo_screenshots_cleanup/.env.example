# ── Input / Output folders ──────────────────────────────────────────────────
INPUT_FOLDER=/path/to/your/iphone/photos
OUTPUT_FOLDER=/path/to/processed/photos

# ── Provider ───────────────────────────────────────────────────────────────
# Choose one: ollama | openai | gemini | bedrock
PROVIDER=ollama

# ── Ollama (PROVIDER=ollama) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava:latest
OLLAMA_MODEL=llama3

# ── OpenAI (PROVIDER=openai) ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o

# ── Gemini (PROVIDER=gemini) ────────────────────────────────────────────────
# GEMINI_API_KEY=AIza...
# GEMINI_VISION_MODEL=gemini-1.5-pro
# GEMINI_MODEL=gemini-1.5-flash

# ── Bedrock (PROVIDER=bedrock) ──────────────────────────────────────────────
# Option A — Bedrock API key (simplest, no IAM setup needed)
#   Generate one in the Bedrock console: short-term (≤12h) or long-term.
#   boto3 picks it up automatically via AWS_BEARER_TOKEN_BEDROCK.
# BEDROCK_API_KEY=...
#
# Option B — Standard AWS credential chain (IAM user / role / ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
#
# Common settings for both options:
# AWS_REGION=us-east-1
# BEDROCK_VISION_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── MCP server ─────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8000

# ── Output ─────────────────────────────────────────────────────────────────
OUTPUT_MARKDOWN_FILE=/path/to/your/flashcards.md
