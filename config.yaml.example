# Spanish Learning Assistant Configuration
# Copy this file to config.yaml and adjust settings as needed.
# Environment variables take precedence over this file.

# LLM provider to use: "ollama" or "bedrock"
llm_provider: ollama

# Ollama configuration
ollama:
  base_url: http://localhost:11434
  model: llama3

# Amazon Bedrock configuration
# Note: API key must be set via environment variable (AWS_BEARER_TOKEN_BEDROCK) or in the UI
bedrock:
  model_id: us.anthropic.claude-3-5-sonnet-20241022-v2:0
  region: us-east-1

# Learning settings
# CEFR level filter: "all", "A1", "A2", "B1", "B2", "C1", "C2"
cefr_level: all
